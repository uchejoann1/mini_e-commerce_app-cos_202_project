# Supabase (browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — required for cart/checkout API routes (copy from Supabase dashboard)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend runs at http://localhost:3000 (npm run dev)
# API: leave empty to use built-in /api routes on the frontend.
# Use http://localhost:5000 only if you run ecommerce-backend separately.
NEXT_PUBLIC_API_BASE_URL=
